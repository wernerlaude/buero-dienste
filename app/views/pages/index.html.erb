<% content_for :hero_content do %>
  <span class="hero__eyebrow">✦ Über <%= User.online.count %> erfahrene Dienstleister</span>
  <h1 class="hero__title">Finden Sie den passenden Bürodienstleister</h1>
  <p class="hero__subtitle">Erfahrene Anbieter für Büroservice, digitale Assistenz und Dokumentenmanagement –
    bundesweit, flexibel und zuverlässig.</p>

  <div class="hero__search">
    <%= form_with(url: root_path, method: :get, class: "hero__search") do |form| %>
      <%= form.text_field :plz, placeholder: "PLZ eingeben …", class: "hero__search-input" %>
      <%= form.submit "Suchen", class: "btn btn--accent btn--lg" %>
    <% end %>
  </div>

  <div class="hero__stats">
    <div>
      <div class="hero__stat-value"><%= User.online.count %></div>
      <div class="hero__stat-label">Dienstleister</div>
    </div>
    <div>
      <div class="hero__stat-value"><%#= number_with_delimiter(@total_visits || 0) %></div>
      <div class="hero__stat-label">Besuchte Angebote</div>
    </div>
    <div>
      <div class="hero__stat-value"><%= Offer.count %></div>
      <div class="hero__stat-label">Fachbereiche</div>
    </div>
  </div>
<% end %>
<% content_for :hero_picture do %>
  <%= image_tag "buero-frau.webp" %>
<% end %>

<%# Intro %>
<div class="intro-box">

  <p class="intro-box__text">
  <h2>Professionelle Unterstützung für Ihren Büroalltag</h2>
  <h3>Entlasten Sie sich mit erfahrenen Bürodienstleistern</h3>
  Auf <%= link_to "buero-dienstleistungen.com", root_path %> finden Sie Fachkräfte
  für Büroservice, Buchhaltung, Telefonservice, digitale Assistenz und viele weitere
  Aufgaben. Alle Dienstleister arbeiten eigenständig und rechnen direkt mit Ihnen ab –
  ohne Vermittlungsgebühren oder versteckte Kosten.
  </p>
  <p class="intro-box__text">
    Ob einmalige Unterstützung bei Projekten oder langfristige Zusammenarbeit:
    Sie entscheiden, wann und wie viel Hilfe Sie brauchen.
  </p>
  <p class="intro-box__text">
    Durchsuchen Sie die Angebote nach <strong>Fachbereich, Bundesland oder Postleitzahl</strong>
    und nehmen Sie direkt Kontakt auf.
  </p><br/>
  <div class="intro-box__divider"></div>
  <div class="intro-box__pills">
    <span class="intro-box__pill">✓ Bundesweit verfügbar</span>
    <span class="intro-box__pill">✓ Keine festen Kosten</span>
    <span class="intro-box__pill">✓ Flexibel buchbar</span>
    <span class="intro-box__pill">✓ Erfahrene Fachkräfte</span>
  </div>
</div>

<%# Kategorien dynamisch aus Offers %>
<% Offer.cached_by_category.sort_by { |cat_id, _| cat_id }.each do |cat_id, cat_offers| %>
  <div class="section-header">
    <h2 class="section-header__title"><%= cat_offers.first.category_name %></h2>
  </div>

  <div class="cards-grid">
    <% cat_offers.each do |offer| %>
      <%= render "shared/category_card", offer: offer %>
    <% end %>
  </div>
<% end %>


