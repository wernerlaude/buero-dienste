<% content_for :hero_content do %>
  <span class="hero__eyebrow">✦ Über <%= User.online.count %> erfahrene Dienstleister</span>
  <h1 class="hero__title">Bürodienstleistungen - Büroservice</h1>
  <p class="hero__subtitle">Erfahrene Anbieter für Büroservice, digitale Assistenz und Dokumentenmanagement –
    bundesweit, flexibel und zuverlässig.</p>

  <div class="hero__search">
    <%= form_with(url: search_users_path, method: :get) do |form| %>
      <%= form.text_field :plz, placeholder: "PLZ eingeben …", class: "hero__search-input", pattern: "\\d{5}" %>
      <%= form.submit "Suchen", class: "btn btn--accent btn--lg" %>
    <% end %>
  </div>

  <div class="hero__stats">
    <div>
      <div class="hero__stat-value"><%= User.online.count %></div>
      <div class="hero__stat-label">Dienstleister</div>
    </div>
    <div>
      <div class="hero__stat-value"><%= @visits_all %></div>
      <div class="hero__stat-label">Besuchte Angebote</div>
    </div>
    <div>
      <div class="hero__stat-value"><%= Offer.count %></div>
      <div class="hero__stat-label">Fachbereiche</div>
    </div>
  </div>
<% end %>
<% content_for :hero_picture do %>
  <%= image_tag "hero/buero-frau.webp", alt: "Büroservice Bürodienstleister" %>
<% end %>

<div class="intro-box">

  <div class="intro-box__text">
    <h2>Professionelle Unterstützung für Ihren Büroalltag</h2>
    <h3>Finden Sie hier den passenden Bürodienstleister</h3>
    <p><b>Entlasten Sie sich mit erfahrenen Bürodienstleistern!</b><br />
      Auf <%= link_to "buero-dienstleistungen.com", root_path %> finden Sie Fachkräfte
      für Büroservice, Buchhaltung, Telefonservice, digitale Assistenz und viele weitere
      Aufgaben. Alle Dienstleister arbeiten eigenständig und rechnen direkt mit Ihnen ab –
      ohne Vermittlungsgebühren oder versteckte Kosten.
    </p>
    <p>
      Ob einmalige Unterstützung bei Projekten oder langfristige Zusammenarbeit:
      Sie entscheiden, wann und wie viel Hilfe Sie brauchen.
    </p>
    <p>
      Durchsuchen Sie die Angebote nach <strong>Fachbereich, Bundesland oder Postleitzahl</strong>
      und nehmen Sie direkt Kontakt auf.
    </p>
  </div>
  <br/>

  <div class="intro-box__pills">
    <span class="intro-box__pill">✓ Bundesweit verfügbar</span>
    <span class="intro-box__pill">✓ Keine festen Kosten</span>
    <span class="intro-box__pill">✓ Flexibel buchbar</span>
    <span class="intro-box__pill">✓ Erfahrene Fachkräfte</span>
  </div>
</div>

<div data-controller="toggle-tabs" data-toggle-tabs-active-value="fachbereiche">

  <div class="toggle-container toggle-container--floating" id="kategorien">
    <div class="toggle-switch">
      <button type="button" class="toggle-option active"
              data-toggle-tabs-target="tab"
              data-tab-id="fachbereiche"
              data-action="click->toggle-tabs#switch">
        Nach Fachbereichen
      </button>
      <button type="button" class="toggle-option"
              data-toggle-tabs-target="tab"
              data-tab-id="bundesland"
              data-action="click->toggle-tabs#switch">
        Nach Bundesland
      </button>
      <button type="button" class="toggle-option"
              data-toggle-tabs-target="tab"
              data-tab-id="plz"
              data-action="click->toggle-tabs#switch">
        PLZ-Suche
      </button>
    </div>
  </div>

  <%# Fachbereiche – sofort geladen %>
  <div data-toggle-tabs-target="panel" data-panel-id="fachbereiche">
    <%= render "pages/category_cards" %>
  </div>

  <%# Bundesland – lazy per Turbo Frame %>
  <turbo-frame id="tab-bundesland" data-toggle-tabs-target="panel" data-panel-id="bundesland"
               src="<%= page_tab_path(:bundesland) %>"
               loading="lazy"
               class="is-hidden">
  </turbo-frame>

  <%# PLZ-Suche – lazy per Turbo Frame %>
  <turbo-frame id="tab-plz" data-toggle-tabs-target="panel" data-panel-id="plz"
               src="<%= page_tab_path(:plz) %>"
               loading="lazy"
               class="is-hidden">
  </turbo-frame>

</div>

