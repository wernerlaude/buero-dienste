<% content_for :hero_content do %>
  <span class="hero__eyebrow">✦ Über <%= User.online.count %> erfahrene Dienstleister</span>
  <h1 class="hero__title">Ein Inserat oder einen Backlink buchen</h1>
  <p class="hero__subtitle">Diese WebPage wird laufend gepflegt und basiert auf modernsten Technologien. Unser Ranking wird täglich
    überwacht und der WebAuftritt optimiert.</p>



  <div class="hero__stats">
    <div>
      <div class="hero__stat-value"><%= User.online.count %></div>
      <div class="hero__stat-label">Dienstleister</div>
    </div>
    <div>
      <div class="hero__stat-value"><%#= number_with_delimiter(@total_visits || 0) %></div>
      <div class="hero__stat-label">Besuchte Angebote</div>
    </div>
    <div>
      <div class="hero__stat-value"><%= Offer.count %></div>
      <div class="hero__stat-label">Fachbereiche</div>
    </div>
  </div>
<% end %>
<% content_for :hero_picture do %>
  <%= image_tag "hero/buero-frau.webp", alt: "Werbung buchen" %>
<% end %>



<%# Intro %>
<div class="intro-box">

  <p class="intro-box__text">Inhalte kommen bald
</div>

<div class="content-box content-box--text">
  <h2>Werbung auf https://www.buero-dienstleistungen.com</h2>

</div>

<% content_for :meta_title do %>
  Werben Sie für sich und Ihr Unternehmen
<% end %>

<% content_for :meta_desc do %>
  Visitenkarten, Werbung, Inserate und Backlinks schalten auf www.buero-dienstleistungen.com
<% end %>

<% content_for :cano do %>
  https://www.buero-dienstleistungen.com/werbung
<% end %>
