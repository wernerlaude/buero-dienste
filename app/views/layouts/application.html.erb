<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? yield(:title) : "Bürodienstleistungen" %> | buero-dienstleistungen.com</title>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body>


<%= render "shared/hero" %>
<%= render "shared/navbar" %>

<% if notice || alert %>
  <div class="flash-messages">
    <% if notice %><div class="flash flash--notice" data-controller="flash"><%= notice %></div><% end %>
    <% if alert %><div class="flash flash--alert" data-controller="flash"><%= alert %></div><% end %>
  </div>
<% end %>

<div class="page">
  <main class="page__main">
    <%= yield %>
  </main>

  <aside class="page__sidebar">
    <%= render "shared/sidebar" %>
  </aside>
</div>

<%= render "shared/footer" %>
</body>
</html>
