<!DOCTYPE html>
<html lang="de">
<head>
  <title><%= content_for(:meta_title) || "Buero Dienste" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="application-name" content="Buero Dienste">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="content-language" content="de_DE">
  <meta name="description" content="<%= yield :meta_desc %>"/>

  <meta property="og:locale" content="de_DE"/>
  <meta property="og:type" content="website"/>
  <meta property="og:title" content="Bürodienstleistungen Büroservice Büroarbeiten"/>
  <meta property="og:description" content="Finden Sie den passenden Bürodienstleister für Ihren Bedarf"/>
  <meta property="og:url" content="https://www.buero-dienstleistungen.com/"/>
  <meta property="og:site_name" content="Bürodienstleistungen & Büroservice"/>
  <meta name="page-topic" content="Bürodienstleistungen & Büroservice einfach finden">
  <meta name="robots" content="index,follow,max-image-preview:large"/>
  <meta name="google-site-verification" content="Is-GJdfnCiSznBbBPdDfQuzaikCIRcBz5lR7SYxbPw4"/>
  <meta name="seobility" content="c4acddfe4057dc59d395212a268d0038">
  <meta name="thumbnail" content="https://www.buero-dienstleistungen.com/images/thumbnail.webp"/>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%# Icons — je einmal reicht %>
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="icon" href="/icon.png" type="image/png">
  <link rel="apple-touch-icon" href="<%= asset_path('apple-icon.png') %>">

  <link rel="canonical" href="<%= yield :cano %>"/>

  <%# Font preloaden — vor den Stylesheets %>
  <%= tag.link rel: "preload",
               href: asset_path("Inter-VariableFont_opsz,wght.woff2"),
               as: "font",
               type: "font/woff2",
               crossorigin: "anonymous" %>

  <%= stylesheet_link_tag :application, "data-turbo-track": "reload" %>
  <%# Falls lexxy wirklich ein separates Bundle braucht: %>
  <%= stylesheet_link_tag "lexxy", "data-turbo-track": "reload" %>

  <%= javascript_importmap_tags %>
  <%= yield :page_scripts %>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "url": "https://www.buero-dienstleistungen.com",
    "name": "Büro Dienstleistungen",
    "description": "Finden Sie professionelle Büroservices, digitale Assistenz, Dokumentenservices und mehr.",
    "inLanguage": "de",
    "publisher": {
      "@type": "Organization",
      "name": "Büro Dienstleistungen",
      "url": "https://www.buero-dienstleistungen.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.buero-dienstleistungen.com/images/thumbnail.webp"
      }
    },
    "image": ["https://www.buero-dienstleistungen.com/images/buero-dienstleistungen.webp"],
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://www.buero-dienstleistungen.com/suche?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
</head>
<body>


<%= render "shared/hero" %>
<%= render "shared/navbar" %>

<% if notice || alert %>
  <div class="flash-messages">
    <% if notice %>
      <div class="flash flash--notice" data-controller="flash"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="flash flash--alert" data-controller="flash"><%= alert %></div>
    <% end %>
  </div>
<% end %>

<div class="page" data-controller="scroll-highlight">
  <main class="page__main <%= yield(:main_class) %>">
    <%= yield %>
  </main>

  <aside class="page__sidebar">
    <%= render "shared/sidebar" %>
  </aside>
</div>

<%= render "shared/footer" %>
<button class="to-top-btn" id="toTopBtn" title="Nach oben" onclick="scrollToTop()">
  <span class="arrow-container">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m18 15-6-6-6 6"/>
    </svg>
  </span>
</button>

<script>
    function scrollToTop() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    window.addEventListener('scroll', function() {
        var btn = document.getElementById('toTopBtn');
        if (window.scrollY > 400) {
            btn.classList.add('visible');
        } else {
            btn.classList.remove('visible');
        }
    });
</script>
</body>
</html>
