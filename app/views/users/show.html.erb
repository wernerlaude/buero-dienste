<% content_for :hero_class, "hero--compact" %>
<% content_for :hero_content do %>
  <% if @user.premium? %>
    <span class="hero__eyebrow">★ Premium Visitenkarte</span>
  <% end %>
  <h1 class="hero__title">
    <%= @user.fullname %> – <%= @user.berufsbezeichnung.presence || @user.firmenname.presence || "Bürodienstleister" %>
  </h1>
  <% content_for :title, "#{@user.fullname} – #{@user.berufsbezeichnung.presence || @user.firmenname.presence || 'Bürodienstleister'} in #{@user.ort}" %>

  <h2 class="hero__title2"><%= @user.firmenname.presence %></h2>
  <p class="hero__subtitle"><%= @user.ort %><%= " · #{@user.berufsbezeichnung}" if @user.berufsbezeichnung.present? %></p>
  <% if @user.offers.any? %>
    <div class="hero__stats">
      <div>
        <div class="hero__stat-value"><%= @user.offers.count %></div>
        <div class="hero__stat-label">Tätigkeitsbereiche</div>
      </div>
    </div>
  <% end %>
<% end %>

<% content_for :hero_picture do %>
  <div class="profile-avatar--hero"><%= @user.initials %></div>
<% end %>

<div class="content-box content-box--compact content-box--profile">
  <div class="profile-split">
    <div class="profile-main">
      <% if @user.erstberatung? %>
        <span class="hero__eyebrow">✓ Kostenlose Erstberatung</span>
      <% end %>

      <h2 class="profile-firma"><%= @user.fullname %></h2>

      <% if @user.berufsbezeichnung.present? %>
        <h3 class="content-box__section-title"><%= @user.berufsbezeichnung %></h3>
      <% end %>

      <% if @user.firmenname.present? %>
        <p class="profile-firma"><%= @user.firmenname %></p>
      <% end %>

      <% if @user.firmenmotto.present? %>
        <p class="profile-motto"><%= @user.firmenmotto %></p>
      <% end %>
    </div>

    <div class="profile-image">
      <% if @user.header_image.attached? %>
        <%= image_tag @user.header_image, alt: @user.fullname, title: @user.fullname %>
      <% else %>
        <div class="profile-avatar--large"><%= @user.initials %></div>
      <% end %>
    </div>
  </div>
</div>

<%# Beschreibung %>
<% if @user.beschreibung.present? %>
  <div class="content-box content-box--compact">
    <div class="profile-description">
      <%= format_text(@user.beschreibung) %>
    </div>
  </div>
<% end %>

<%# Tätigkeitsbereiche %>
<% if @user.offers.any? %>
  <div class="content-box content-box--compact">
    <h3 class="content-box__section-title">Tätigkeitsbereiche</h3>
    <div class="intro-box__pills">
      <% @user.offers.each do |offer| %>
        <span class="intro-box__pill"><%= offer.title %></span>
      <% end %>
    </div>
  </div>
<% end %>

<%# Zusatzangebote %>
<% if @user.other_offers.present? %>
  <div class="content-box content-box--compact">
    <h3 class="content-box__section-title">Zusatzangebote</h3>
    <p><%= @user.other_offers %></p>
  </div>
<% end %>

<%= content_for :sidebar do %>
  <div class="sidebar-card sidebar-card--muted">
    <% if @user.uploads[0].present? %>
      <div class="partner-card__image">
        <%= image_tag @user.uploads[0], alt: "Logo #{@user.fullname}" %>
      </div>
    <% end %>

    <h3 class="sidebar-card__header">Kontakt</h3>
    <div class="sidebar-card__body">
      <%# Name & Firma %>
      <div class="contact-block">
        <% if @user.display_name? %>
          <p class="premium-entry__name"><%= @user.anrede %> <%= @user.fullname %></p>
        <% end %>
        <% if @user.firmenname.present? %>
          <p class="partner-card__company"><%= @user.firmenname %></p>
        <% end %>
        <% if @user.gesellschaftsform.present? %>
          <p class="partner-card__location"><%= @user.gesellschaftsform %></p>
        <% end %>
      </div>

      <%# Adresse %>
      <div class="contact-block">
        <p>
          <%= @user.strasse %><br>
          <%= @user.plz %> <%= @user.ort %>
        </p>
      </div>

      <%# Erreichbarkeit %>
      <div class="contact-block">
        <p><%= mail_to @user.email, @user.email %></p>
        <% if @user.telefon.present? %>
          <p>Tel: <%= link_to @user.telefon, "tel:#{@user.telefon}" %></p>
        <% end %>
        <% if @user.mobile.present? %>
          <p>Mobil: <%= link_to @user.mobile, "tel:#{@user.mobile}" %></p>
        <% end %>
        <% if @user.webpage.present? %>
          <p><%= safe_webpage_link(@user.webpage) %></p>
        <% end %>
      </div>

      <%# Maps %>
      <% if @user.maps.present? %>
        <div class="contact-block">
          <%= link_to "→ Anfahrt Google Maps",
                      "http://maps.google.com/?q=#{@user.fulladdress}",
                      target: "_blank", rel: "noopener" %>
        </div>
      <% end %>
    </div>

    <div class="partner-card__action">
      <%= mail_to @user.email, "» #{@user.fullname} kontaktieren «",
                  subject: "Ihre Visitenkarte auf: www.buero-dienstleistungen.com",
                  class: "btn btn--primary" %>
    </div>
  </div>
<% end %>

<% content_for :meta_title do %>
<%= @user.meta_title + ' in ' + @user.ort %>
<% end %>

<% content_for :meta_desc do %>
<%= @user.meta_desc %>
<% end %>

<% content_for :cano do %>
https://www.buero-dienstleistungen.com/ihr-partner/<%= @user.id %>-<%= @user.for_cano.parameterize %>
<% end %>