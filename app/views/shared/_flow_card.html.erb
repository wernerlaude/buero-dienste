<% button_text ||= "» Beispiele Ansehen «" %>
<% button_path ||= "https://www.workflow-digital.com" %>
<% image ||= nil %>

<article class="partner-card">
  <% if image.present? %>
    <div class="partner-card__image">
      <%= image_tag image, alt: "Digitalisierung für KMU's" %>
    </div>
  <% end %>
  <div class="partner-card__body">
    <h4 class="partner-card__name">Digitalisierung für KMU's</h4>
    <p class="partner-card__company">
      Von der Analyse bis zur fertigen Lösung. Geschäftsprozesse vereinfachen.
      Ich <strong>digitalisiere</strong> Ihre Arbeitsabläufe.
    </p>
  </div>

    <div class="partner-card__action">
      <%= link_to button_text, button_path, target: "_blank", class: "btn btn--accent" %>
    </div>

</article>