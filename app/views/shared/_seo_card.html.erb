<% button_text ||= "» Mehr Informationen «" %>
<% button_path ||= "https://www.webdesign-webpages.de/seo-optimierung" %>
<% image ||= nil %>

<article class="partner-card">
  <% if image.present? %>
    <div class="partner-card__image">
      <%= image_tag image, alt: "Suchmaschinen Optimierung" %>
    </div>
  <% end %>
  <div class="partner-card__body">
    <h4 class="partner-card__name">Google Ranking</h4>
    <p class="partner-card__company">
      Diese Seite wird bestens bei Google gefunden. Wenn Sie das für Ihren Webauftritt auch möchten, lassen Sie uns drüber sprechen.
    </p>
  </div>

    <div class="partner-card__action">
      <%= link_to button_text, button_path, target: "_blank", class: "btn btn--accent" %>
    </div>

</article>