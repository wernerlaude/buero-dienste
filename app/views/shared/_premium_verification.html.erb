<%= turbo_frame_tag :login_frame, target: "_top" do %>
  <% if local_assigns[:error] %>
    <p class="sidebar-login__error"><%= error %></p>
  <% end %>

  <%= form_with(url: premium_auth_verification_path, data: { turbo: true }) do |form| %>
    <div class="form-group">
      <%= form.text_field :verification_code,
                          placeholder: "6-stelliger Code",
                          required: true,
                          maxlength: 6,
                          inputmode: "numeric",
                          autocomplete: "one-time-code",
                          class: "sidebar-login__input sidebar-login__input--code" %>
    </div>
    <%= form.submit "Einloggen", class: "btn btn--primary btn--full" %>
  <% end %>

  <p class="sidebar-login__hint">Code nicht erhalten?
    <%= form_with url: premium_auth_path,
                  data: { turbo_frame: "login_frame" } do |f| %>
      <%= f.hidden_field :email, value: session[:premium_email] %>
      <%= f.submit "Nochmal senden", class: "sidebar-login__link" %>
    <% end %>
  </p>
<% end %>