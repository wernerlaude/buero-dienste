<% header ||= "Tags" %>

<div class="sidebar-card">
  <h3 class="sidebar-card__header"><%= header %></h3>
  <div class="sidebar-card__body">
    <% tags.each do |tag| %>
      <div class="premium-entry premium-entry--compact">
        <div class="premium-entry__info">
          <div class="premium-entry__name"><%= tag.name %></div>
          <%= link_to "Nachschaun →", tag.verweis, class: "premium-entry__link" %>
        </div>
      </div>
    <% end %>
  </div>
</div>