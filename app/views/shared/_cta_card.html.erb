<% button_text ||= "» Jetzt Visitenkarte anlegen «" %>
<% button_path ||= new_user_path %>
<% image ||= nil %>

<article class="partner-card">
  <% if image.present? %>
    <div class="partner-card__image">
      <%= image_tag image, alt: "Kostenlose Visitenkarte anlegen" %>
    </div>
  <% end %>
  <div class="partner-card__body">
    <h4 class="partner-card__name">Neue Kunden gewinnen?</h4>
    <p class="partner-card__company">
      Nutzen Sie unser gutes Ranking für Ihr Business!
      Jede unsere Visitenkarten wurde zwischen
      <strong><%= visits_min %></strong> und
      <strong><%= visits_max %></strong> mal angesehen.
    </p>
  </div>

    <div class="partner-card__action">
      <%= link_to button_text, button_path, class: "btn btn--accent" %>
    </div>

</article>