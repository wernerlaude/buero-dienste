<div class="sidebar-card">
  <%# if logged_in? %>
    <h3 class="sidebar-card__header">Mein Bereich</h3>
    <div class="sidebar-card__body">
      <p class="premium-entry__name"><%#= current_user.name %></p>
      <%#=link_to "Visitenkarte bearbeiten", edit_business_card_path, class: "btn btn--primary btn--full" %>
      <div style="margin-top: var(--space-sm);">
        <%#= button_to "Ausloggen", premium_auth_path, method: :delete, class: "btn btn--ghost btn--full" %>
      </div>
    </div>
  <%# else %>
    <h3 class="sidebar-card__header">Premium Login</h3>
    <div class="sidebar-card__body">
      <%#= turbo_frame_tag :login_frame do %>
        <%#= form_with(url: premium_auth_path, data: { turbo_frame: "login_frame" }) do |form| %>
          <div class="form-group">
            <%#= form.email_field :email, placeholder: "Ihre E-Mail Adresse",
                                 required: true, class: "sidebar-login__input" %>
          </div>
          <%#= form.submit "Code senden", class: "btn btn--primary btn--full" %>
          <p class="sidebar-login__hint">
            Wir senden Ihnen einen Verifikations-Code an Ihre registrierte E-Mail.
          </p>
        <%# end %>
      <%# end %>
    </div>
  <%# end %>
</div>

<%# Premium Einträge %>
<%# if @premium_users.present? %>
  <div class="sidebar-card">
    <h3 class="sidebar-card__header">Premium Einträge</h3>
    <div class="sidebar-card__body">
      <%# @premium_users.each do |user| %>
        <div class="premium-entry">
          <div class="premium-entry__avatar"><%#= user.name.split.map(&:first).join %></div>
          <div class="premium-entry__info">
            <div class="premium-entry__name"><%#= user.name %></div>
            <div class="premium-entry__location"><%#= user.plz %> <%#= user.ort %></div>
            <%#= link_to "Profil besuchen →", user_path(user), class: "premium-entry__link" %>
          </div>
        </div>
      <%# end %>
    </div>
  </div>
<%# end %>

<%# Werbung %>
<div class="sidebar-card">
  <div class="sidebar-card__body sidebar-ad">
    <div class="sidebar-ad__title">Werbung schalten</div>
    <div class="sidebar-ad__text">Erreichen Sie Ihre Zielgruppe auf unserem Portal.</div>
    <%#= link_to "Mehr erfahren", werbung_path, class: "btn btn--ghost" %>
  </div>
</div>