<%= turbo_frame_tag :login_frame do %>
  <%= form_with(url: premium_auth_path, data: { turbo: true }) do |form| %>
    <div class="form-group">
      <p class="sidebar-login__hint">Ihre bei uns registrierte E-Mail.</p>
      <%= form.email_field :email,
                           placeholder: "Ihre E-Mail Adresse",
                           required: true,
                           class: "sidebar-login__input" %>
    </div>
    <%= form.submit "Code senden", class: "btn btn--primary btn--full" %>
  <% end %>
<% end %>