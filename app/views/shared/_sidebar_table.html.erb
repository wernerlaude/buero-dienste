<% header ||= "Blog Posts" %>
<div class="sidebar-card">
  <h3 class="sidebar-card__header"><%= header %></h3>
  <div class="sidebar-card__body">
    <% blog_posts.each do |post| %>
      <div class="premium-entry premium-entry--compact <%= 'premium-entry--active' if @latest_blog_post == post.id %>">
        <div class="premium-entry__info">
          <div class="premium-entry__name"><%= post.list_title %></div>
          <%= link_to "Lesen →", blog_post_path(post), class: "premium-entry__link" %>
        </div>
      </div>
    <% end %>
  </div>
</div>