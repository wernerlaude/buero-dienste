<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Willkommen bei buero-dienstleistungen.com</title>
  <style type="text/css">
      * {
          margin: 0;
          padding: 0;
          box-sizing: border-box;
      }

      body {
          font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
          font-size: 16px;
          line-height: 1.6;
          color: #2d3748;
          background-color: #E1ECF4;
          -webkit-font-smoothing: antialiased;
      }

      .email-wrapper {
          width: 100%;
          padding: 32px 16px;
          background-color: #E1ECF4;
      }

      .email-container {
          max-width: 600px;
          margin: 0 auto;
          background: #ffffff;
          border-radius: 8px;
          overflow: hidden;
          border: 1px solid #cacaca;
      }

      /* Header */
      .email-header {
          background: linear-gradient(135deg, #28538F 0%, #2c5282 100%);
          padding: 32px 40px;
          text-align: left;
      }

      .email-header h1 {
          color: #ffffff;
          font-size: 22px;
          font-weight: 700;
          margin: 0 0 4px;
      }

      .email-header p {
          color: rgba(255, 255, 255, 0.7);
          font-size: 14px;
          margin: 0;
      }

      .email-header__logo {
          display: inline-block;
          width: 36px;
          height: 36px;
          background: rgba(255, 255, 255, 0.15);
          border-radius: 6px;
          text-align: center;
          line-height: 36px;
          color: #fff;
          font-weight: 700;
          font-size: 16px;
          margin-bottom: 12px;
      }

      /* Badge */
      .email-badge {
          display: inline-block;
          background: #fef7eb;
          color: #d4922a;
          font-size: 12px;
          font-weight: 700;
          text-transform: uppercase;
          letter-spacing: 0.08em;
          padding: 4px 12px;
          border-radius: 100px;
          margin-bottom: 16px;
      }

      /* Body */
      .email-body {
          padding: 32px 40px;
      }

      .email-body h2 {
          font-size: 20px;
          font-weight: 700;
          color: #2c5282;
          margin: 0 0 8px;
      }

      .email-body h3 {
          font-size: 16px;
          font-weight: 600;
          color: #2d3748;
          margin: 24px 0 8px;
      }

      .email-body p {
          font-size: 15px;
          line-height: 1.7;
          color: #2d3748;
          margin: 0 0 12px;
      }

      .email-body a {
          color: #28538F;
          text-decoration: underline;
      }

      /* Divider */
      .email-divider {
          border: none;
          height: 2px;
          background: #e8a838;
          margin: 24px 0;
          width: 60px;
      }

      /* Info Box */
      .email-info {
          background: #E1ECF4;
          border-left: 4px solid #28538F;
          border-radius: 0 6px 6px 0;
          padding: 16px 20px;
          margin: 20px 0;
      }

      .email-info p {
          font-size: 14px;
          color: #2d3748;
          margin: 0 0 4px;
      }

      .email-info p:last-child {
          margin-bottom: 0;
      }

      /* Button */
      .email-btn {
          display: inline-block;
          background: #28538F;
          color: #ffffff !important;
          font-size: 15px;
          font-weight: 700;
          padding: 12px 28px;
          border-radius: 100px;
          text-decoration: none;
          margin: 8px 0;
      }

      .email-btn--accent {
          background: #e8a838;
      }

      /* Steps */
      .email-steps {
          margin: 20px 0;
      }

      .email-step {
          display: flex;
          align-items: flex-start;
          margin-bottom: 12px;
      }

      .email-step__number {
          display: inline-block;
          width: 28px;
          height: 28px;
          background: #28538F;
          color: #fff;
          font-size: 13px;
          font-weight: 700;
          text-align: center;
          line-height: 28px;
          border-radius: 50%;
          margin-right: 12px;
          flex-shrink: 0;
      }

      .email-step__text {
          font-size: 15px;
          color: #2d3748;
          padding-top: 3px;
      }

      /* Signature */
      .email-signature {
          margin-top: 24px;
          padding-top: 16px;
          border-top: 1px solid #dedee4;
      }

      .email-signature p {
          font-size: 14px;
          color: #718096;
          margin: 0;
      }

      .email-signature strong {
          color: #2d3748;
      }

      /* Footer */
      .email-footer {
          background: #2c5282;
          padding: 20px 40px;
          text-align: center;
      }

      .email-footer p {
          color: rgba(255, 255, 255, 0.6);
          font-size: 12px;
          margin: 0 0 4px;
      }

      .email-footer a {
          color: rgba(255, 255, 255, 0.8);
          text-decoration: none;
      }

      /* Responsive */
      @media only screen and (max-width: 640px) {
          .email-body,
          .email-header,
          .email-footer {
              padding-left: 20px !important;
              padding-right: 20px !important;
          }

          .email-header h1 {
              font-size: 18px !important;
          }
      }
  </style>
</head>
<body>
<div class="email-wrapper">
  <div class="email-container">

    <!-- Header -->
    <div class="email-header">
      <div class="email-header__logo">B</div>
      <h1>buero-dienstleistungen.com</h1>
      <p>Ihr Portal für Bürodienstleistungen</p>
    </div>

    <!-- Body -->
    <div class="email-body">
      <span class="email-badge">✦ Willkommen</span>

      <h2>Danke für Ihre Anmeldung!</h2>
      <hr class="email-divider">

      <p>Hallo <%= @user.anrede %> <%= @user.fullname %>,</p>
      <p>wir freuen uns, dass Sie dabei sind und Ihr Angebot auf unserem Portal veröffentlichen möchten.</p>

      <h3>Wie geht es weiter?</h3>

      <table class="email-steps" width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <td style="padding-bottom: 12px;">
            <table cellpadding="0" cellspacing="0"><tr>
              <td style="vertical-align: top; padding-right: 12px;">
                <span class="email-step__number">1</span>
              </td>
              <td style="vertical-align: top;">
                <span class="email-step__text">Ich wurde benachrichtigt und schalte Ihre Visitenkarte zeitnah frei.</span>
              </td>
            </tr></table>
          </td>
        </tr>
        <tr>
          <td style="padding-bottom: 12px;">
            <table cellpadding="0" cellspacing="0"><tr>
              <td style="vertical-align: top; padding-right: 12px;">
                <span class="email-step__number">2</span>
              </td>
              <td style="vertical-align: top;">
                <span class="email-step__text">Senden Sie mir gerne weitere Texte, Bilder oder Logos per E-Mail.</span>
              </td>
            </tr></table>
          </td>
        </tr>
        <tr>
          <td style="padding-bottom: 12px;">
            <table cellpadding="0" cellspacing="0"><tr>
              <td style="vertical-align: top; padding-right: 12px;">
                <span class="email-step__number">3</span>
              </td>
              <td style="vertical-align: top;">
                <span class="email-step__text">Sollten Sie innerhalb von 3 Tagen nichts hören, nehmen Sie bitte Kontakt auf.</span>
              </td>
            </tr></table>
          </td>
        </tr>
      </table>

      <div class="email-info">
        <p><strong>Bilder und Korrekturen an:</strong></p>
        <p><a href="mailto:support@buero-dienstleistungen.com">support@buero-dienstleistungen.com</a></p>
      </div>

      <p style="text-align: center; margin-top: 24px;">
        <a href="https://www.buero-dienstleistungen.com" class="email-btn">Zur Webseite →</a>
      </p>

      <!-- Signatur -->
      <div class="email-signature">
        <p>Herzliche Grüße</p>
        <p><strong>Werner Laude</strong></p>
        <p>buero-dienstleistungen.com</p>
      </div>
    </div>

    <!-- Footer -->
    <div class="email-footer">
      <p>© <%= Date.current.year %> buero-dienstleistungen.com</p>
      <p><a href="https://www.buero-dienstleistungen.com">www.buero-dienstleistungen.com</a></p>
    </div>

  </div>
</div>
</body>
</html>
